<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:EkadashiReminder"
             xmlns:conv="clr-namespace:EkadashiReminder.Converters"
             x:Class="EkadashiReminder.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:NotNullConverter x:Key="NotNullConverter" />
            <conv:NotNullOrEmptyConverter x:Key="NotNullOrEmptyConverter" />
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
            <conv:DaysColorConverter x:Key="DaysColorConverter" />
            <conv:CustomColorConverter x:Key="CustomColorConverter" />
            <conv:ReminderStatusLabelConverter x:Key="ReminderStatusLabelConverter" />
            <conv:ReminderStatusColorConverter x:Key="ReminderStatusColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
